<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Northway Construction | Commercial General Contractor</title>
  <meta name="description" content="{{ description }}">

  <meta property="og:title" content="{{ title }} | Northway Construction">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="website">

  <link rel="icon" type="image/png" href="/images/logo-black.png">

  <link rel="stylesheet" href="/css/styles.css">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "GeneralContractor",
    "name": "Northway Construction Inc.",
    "description": "Trusted commercial general contractor delivering cost-effective, high-quality construction across Utah and Washington for over 20 years.",
    "url": "https://northwayinc.com",
    "logo": "https://northwayinc.com/images/logo-black.png",
    "telephone": "(385) 208-4433",
    "email": "info@northwayinc.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "3535 Ranches Parkway, Suite C",
      "addressLocality": "Eagle Mountain",
      "addressRegion": "UT",
      "postalCode": "84005",
      "addressCountry": "US"
    },
    "areaServed": [
      {
        "@type": "State",
        "name": "Utah"
      },
      {
        "@type": "State",
        "name": "Washington"
      }
    ],
    "sameAs": [
      "https://www.facebook.com/northwayinc"
    ]
  }
  </script>

  {{ schema | safe }}
</head>
<body>

  {% include "header.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

</body>
</html>
