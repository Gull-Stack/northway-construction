<!-- Contact Form -->
<section class="section-light">
  <div class="container">
    <div style="max-width: 700px; margin: 0 auto; text-align: center; margin-bottom: 2rem;">
      <span class="section-label">Get in Touch</span>
      <h2>Start Your Project Today</h2>
      <p>Fill out the form below and we'll get back to you within one business day to discuss your commercial construction needs.</p>
    </div>

    <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="contact">

      <!-- Honeypot field -->
      <p style="display: none;">
        <label>Don't fill this out if you're human: <input name="bot-field"></label>
      </p>

      <div class="form-group">
        <label for="name">Full Name *</label>
        <input type="text" id="name" name="name" required>
      </div>

      <div class="form-group">
        <label for="email">Email Address *</label>
        <input type="email" id="email" name="email" required>
      </div>

      <div class="form-group">
        <label for="phone">Phone Number *</label>
        <input type="tel" id="phone" name="phone" required>
      </div>

      <div class="form-group">
        <label for="company">Company Name</label>
        <input type="text" id="company" name="company">
      </div>

      <div class="form-group">
        <label for="project-type">Project Type *</label>
        <select id="project-type" name="project-type" required>
          <option value="">Select a project type</option>
          <option value="office">Office Building / Tenant Improvement</option>
          <option value="religious-educational">Religious & Educational</option>
          <option value="historical">Historical Restoration</option>
          <option value="government">Government & Military</option>
          <option value="renovation">Commercial Renovation</option>
          <option value="ground-up">Ground-Up Construction</option>
          <option value="pre-construction">Pre-Construction Services Only</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="form-group">
        <label for="location">Project Location</label>
        <input type="text" id="location" name="location" placeholder="City, State">
      </div>

      <div class="form-group">
        <label for="message">Project Details *</label>
        <textarea id="message" name="message" required placeholder="Tell us about your project, timeline, and any specific requirements..."></textarea>
      </div>

      <div class="form-group">
        <button type="submit" class="btn btn-primary" style="width: 100%;">Submit Inquiry</button>
      </div>

      <p style="font-size: 0.9rem; color: var(--color-text-light); text-align: center; margin-top: 1rem;">
        * Required fields. We respect your privacy and will never share your information.
      </p>
    </form>
  </div>
</section>

